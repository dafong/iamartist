{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iamartist",
  "version": "0.1.0",
  "identifier": "com.lunar.iamartist",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iamartist",
        "width": 480,
        "height": 280,
        "minWidth": 320,
        "minHeight": 280,
        "maxHeight": 280,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/psd_composite"]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2MjA5NkQ2QjBCOUY5NkMKUldScytibXcxcFlnUnI4UHZhUEZvWDdtWUFmZXg3ZkxsaVBIMFZTQjVMdUNFR0lVejE1bGk1QTYK",
      "endpoints": [
        "https://your-update-server.com/iamartist/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
